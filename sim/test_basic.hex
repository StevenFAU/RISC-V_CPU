// RV32I Integration Test — Hand-assembled hex
// Each line is one 32-bit instruction (word-addressed, address 0, 4, 8, ...)
// Tests: I-type, R-type, Branch, LUI, JAL, JALR, Load/Store
//
// Program:
// 0x00: addi x1, x0, 5         -> 00500093
// 0x04: addi x2, x0, 10        -> 00A00113
// 0x08: addi x3, x0, -1        -> FFF00193
// 0x0C: add  x4, x1, x2        -> 002081B3
// 0x10: sub  x5, x2, x1        -> 401102B3
// 0x14: and  x6, x1, x2        -> 0020F333
// 0x18: or   x7, x1, x2        -> 0020E3B3
// 0x1C: xor  x8, x1, x2        -> 0020C433
// 0x20: sll  x9, x1, x2        -> 002094B3  (shift by x2[4:0]=10)
// 0x24: slt  x10, x3, x1       -> 0011A533  (-1 < 5 signed = 1)
// 0x28: sltu x11, x1, x3       -> 0030B5B3  (5 < 0xFFFFFFFF unsigned = 1)
// 0x2C: slli x12, x1, 2        -> 00209613  (5<<2=20)
// 0x30: srli x13, x2, 1        -> 00115693  (10>>1=5)
// 0x34: srai x14, x3, 4        -> 4011D713  (-1>>>4=-1)
// 0x38: addi x15, x0, 0        -> 00000793
// 0x3C: beq  x1, x1, +8        -> 00108463  (skip next, go to 0x44)
// 0x40: addi x15, x0, 99       -> 06300793  (SKIPPED)
// 0x44: addi x15, x0, 1        -> 00100793
// 0x48: bne  x1, x2, +8        -> 00209463  (skip next, go to 0x50)
// 0x4C: addi x16, x0, 99       -> 06300813  (SKIPPED)
// 0x50: addi x16, x0, 2        -> 00200813
// 0x54: lui  x17, 0xDEADB      -> DEADB8B7
// 0x58: auipc x18, 0           -> 00000917
// --- Build 0xDEADBEEF in x24 ---
// 0x5C: addi x24, x0, 0xDE     -> 0DE00C13  (x24 = 222)
// 0x60: slli x24, x24, 8       -> 008C1C13  (x24 = 0xDE00)
// 0x64: addi x25, x0, 0xAD     -> 0AD00C93  (x25 = 173)
// 0x68: or   x24, x24, x25     -> 019C6C33  (x24 = 0xDEAD)
// 0x6C: slli x24, x24, 8       -> 008C1C13  (x24 = 0xDEAD00)
// 0x70: addi x25, x0, 0xBE     -> 0BE00C93  (x25 = 190)
// 0x74: or   x24, x24, x25     -> 019C6C33  (x24 = 0xDEADBE)
// 0x78: slli x24, x24, 8       -> 008C1C13  (x24 = 0xDEADBE00)
// 0x7C: addi x25, x0, 0xEF     -> 0EF00C93  (x25 = 239)
// 0x80: or   x24, x24, x25     -> 019C6C33  (x24 = 0xDEADBEEF)
// --- Store signature ---
// 0x84: addi x26, x0, 0        -> 00000D13  (x26 = 0)
// 0x88: sw   x24, 0(x26)       -> 018D2023  (store at addr 0)
// 0x8C: lw   x27, 0(x26)       -> 000D2D83  (load back)
// 0x90: lb   x28, 0(x26)       -> 000D0E03  (byte load signed)
// 0x94: lbu  x29, 0(x26)       -> 000D4E83  (byte load unsigned)
// --- JAL test ---
// 0x98: jal  x19, +8           -> 008009EF  (jump to 0xA0, x19=0x9C)
// 0x9C: addi x20, x0, 99       -> 06300A13  (SKIPPED)
// 0xA0: addi x20, x0, 3        -> 00300A13  (JAL worked)
// --- Halt ---
// 0xA4: ecall                   -> 00000073
